# ========= Discord bot (discord.js) =========
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: guild slash-command deploy target (see README / deploy script).
# DISCORD_GUILD_ID=

# ========= Dashboard API + OAuth =========
# Same Application can serve bot + OAuth; use OAuth2 "Client Secret" from Developer Portal.
DISCORD_CLIENT_SECRET=

# Must match URLs registered under Discord → OAuth2 → Redirects (exact match).
# Development: use Vite dev URL so cookies work via proxy (npm run dev:dashboard).
FRONTEND_URL=http://localhost:5173
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback
DISCORD_BOT_REDIRECT_URI=http://localhost:5173/api/auth/bot/callback

# API server (Vite proxies /api → this port).
API_PORT=4000

# Strong random string for signing session cookies.
JWT_SECRET=

# Optional: 32-byte key (hex/base64) for encrypting OAuth tokens at rest.
# TOKEN_ENCRYPTION_KEY=

# MongoDB connection string (local example below).
MONGODB_URI=mongodb://127.0.0.1:27017/discord_dashboard

# Permissions bitmask for bot invite URL (override if needed).
# DISCORD_BOT_PERMISSIONS=277025508352

# Production HTTPS: set COOKIE_SECURE=true
# COOKIE_SECURE=false

# Optional request size limit for API JSON parser.
# API_JSON_LIMIT_MB=1

# Default settings for new guilds/servers
# DEFAULT_MAX_CHARS_PER_DAY=10000
# DEFAULT_PLAN=free

# Session and Rate Limiting
# SESSION_MAX_AGE_MS=604800000
# API_RATE_LIMIT_MAX=120
